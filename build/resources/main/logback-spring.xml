<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <property name="LOG_DIR" value="logs"/>

    <!-- 로그 패턴 -->
    <property name="INFO_PATTERN"
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%X{traceId}] %logger{30} - %msg%n"/>
    <property name="ERROR_PATTERN"
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [traceId=%X{traceId}] [%X{method} %X{uri}] [userId=%X{userId}] %logger{30} - %msg%n%ex{10}"/>
    <property name="CONSOLE_PATTERN"
              value="%d{HH:mm:ss.SSS} %-5level [%X{traceId}] %logger{30} - %msg%n"/>

    <!-- CONSOLE appender -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${CONSOLE_PATTERN}</pattern>
        </encoder>
    </appender>

    <!-- settlement info/error -->
    <appender name="SETTLEMENT_INFO" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_DIR}/settlement/settlement-info.log</file>
        <filter class="ch.qos.logback.classic.filter.LevelFilter">
            <level>INFO</level>
            <onMatch>ACCEPT</onMatch>
            <onMismatch>DENY</onMismatch>
        </filter>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${LOG_DIR}/settlement/settlement-info.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>30</maxHistory>
        </rollingPolicy>
        <encoder><pattern>${INFO_PATTERN}</pattern></encoder>
    </appender>

    <appender name="SETTLEMENT_ERROR" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_DIR}/settlement/settlement-error.log</file>
        <filter class="ch.qos.logback.classic.filter.LevelFilter">
            <level>ERROR</level>
            <onMatch>ACCEPT</onMatch>
            <onMismatch>DENY</onMismatch>
        </filter>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${LOG_DIR}/settlement/settlement-error.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>90</maxHistory>
        </rollingPolicy>
        <encoder><pattern>${ERROR_PATTERN}</pattern></encoder>
    </appender>

    <!-- sale info/error -->
    <appender name="SALE_INFO" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_DIR}/sale/sale-info.log</file>
        <filter class="ch.qos.logback.classic.filter.LevelFilter">
            <level>INFO</level>
            <onMatch>ACCEPT</onMatch>
            <onMismatch>DENY</onMismatch>
        </filter>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${LOG_DIR}/sale/sale-info.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>30</maxHistory>
        </rollingPolicy>
        <encoder><pattern>${INFO_PATTERN}</pattern></encoder>
    </appender>

    <appender name="SALE_ERROR" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_DIR}/sale/sale-error.log</file>
        <filter class="ch.qos.logback.classic.filter.LevelFilter">
            <level>ERROR</level>
            <onMatch>ACCEPT</onMatch>
            <onMismatch>DENY</onMismatch>
        </filter>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${LOG_DIR}/sale/sale-error.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>90</maxHistory>
        </rollingPolicy>
        <encoder><pattern>${ERROR_PATTERN}</pattern></encoder>
    </appender>

    <!-- admin info/error (인증, 회원, 수수료, 스케줄러 등) -->
    <appender name="ADMIN_INFO" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_DIR}/admin/admin-info.log</file>
        <filter class="ch.qos.logback.classic.filter.LevelFilter">
            <level>INFO</level>
            <onMatch>ACCEPT</onMatch>
            <onMismatch>DENY</onMismatch>
        </filter>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${LOG_DIR}/admin/admin-info.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>30</maxHistory>
        </rollingPolicy>
        <encoder><pattern>${INFO_PATTERN}</pattern></encoder>
    </appender>

    <appender name="ADMIN_ERROR" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_DIR}/admin/admin-error.log</file>
        <filter class="ch.qos.logback.classic.filter.LevelFilter">
            <level>ERROR</level>
            <onMatch>ACCEPT</onMatch>
            <onMismatch>DENY</onMismatch>
        </filter>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${LOG_DIR}/admin/admin-error.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>90</maxHistory>
        </rollingPolicy>
        <encoder><pattern>${ERROR_PATTERN}</pattern></encoder>
    </appender>

    <!-- audit log: 정산 상태 변경 감사. 1년 보관. -->
    <appender name="AUDIT" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_DIR}/audit/audit.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${LOG_DIR}/audit/audit.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>365</maxHistory>
        </rollingPolicy>
        <encoder><pattern>${ERROR_PATTERN}</pattern></encoder>
    </appender>

    <!-- 도메인별 로거 연결 -->
    <logger name="com.settlement.manager.domain.settlement" level="INFO" additivity="false">
        <appender-ref ref="SETTLEMENT_INFO"/>
        <appender-ref ref="SETTLEMENT_ERROR"/>
    </logger>

    <logger name="com.settlement.manager.domain.sale" level="INFO" additivity="false">
        <appender-ref ref="SALE_INFO"/>
        <appender-ref ref="SALE_ERROR"/>
    </logger>

    <logger name="com.settlement.manager.domain.user" level="INFO" additivity="false">
        <appender-ref ref="ADMIN_INFO"/>
        <appender-ref ref="ADMIN_ERROR"/>
    </logger>

    <logger name="com.settlement.manager.domain.feerate" level="INFO" additivity="false">
        <appender-ref ref="ADMIN_INFO"/>
        <appender-ref ref="ADMIN_ERROR"/>
    </logger>

    <logger name="com.settlement.manager.infrastructure" level="INFO" additivity="false">
        <appender-ref ref="ADMIN_INFO"/>
        <appender-ref ref="ADMIN_ERROR"/>
    </logger>

    <!-- AUDIT_LOGGER: AuditLogger.java에서 직접 참조 -->
    <logger name="AUDIT_LOGGER" level="INFO" additivity="false">
        <appender-ref ref="AUDIT"/>
    </logger>

    <!-- 환경별 root -->
    <springProfile name="local,test,default">
        <root level="DEBUG">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>

    <springProfile name="prod">
        <root level="WARN"/>
    </springProfile>

</configuration>